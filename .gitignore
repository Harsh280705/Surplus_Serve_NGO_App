google-services.json
GoogleService-Info.plist

# Android Sensitive Files
android/local.properties
android/**/keystore
android/**/*.keystore
android/key.properties
*.jks
*.keystore

# iOS Sensitive Files
ios/**/*.entitlements
ios/**/*.p8
ios/**/*.mobileprovision
ios/**/*.cer

# Python
venv/
env/
__pycache__/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

